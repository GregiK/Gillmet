# Adres bazowy backendu n8n (Gillmet_MES_Dashboard_API)
N8N_BASE_URL=https://automatyzacja.zabawkijuniora.pl/webhook

# Sekret do podpisywania cookie sesji logowania (dowolny dlugi losowy ciag znakow).
# WAZNE: ustaw wlasna wartosc w Vercel (Project Settings -> Environment Variables),
# w przeciwnym razie uzyty zostanie niebezpieczny sekret domyslny.
SESSION_SECRET=zmien-mnie-na-dlugi-losowy-ciag-znakow

# Logowanie przez Google (opcjonalne - bez tych zmiennych przycisk "Zaloguj przez Google"
# pokaze blad, reszta logowania dziala normalnie). Utworz OAuth Client ID w Google Cloud
# Console (patrz README.md, sekcja "Logowanie przez Google").
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Musi dokladnie odpowiadac "Authorized redirect URI" w Google Cloud Console.
GOOGLE_REDIRECT_URI=https://gillmet.vercel.app/api/auth/google/callback
